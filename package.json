{
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "prepare": "husky install",
    "testChanged": "jest --watch --coverage=false --changedSince=origin/main",
    "testDebugCurrent": "jest -o --watch --coverage=false",
    "test": "jest",
    "member:set": "node functions/scripts/set-member-from-planning-center.cjs",
    "member:bulk-seed": "node functions/scripts/bulk-seed-members-from-planning-center.cjs",
    "member:link-by-email": "node functions/scripts/link-members-to-firebase-users-by-email.cjs",
    "member:bulk-sync": "node functions/scripts/bulk-sync-members-from-planning-center.cjs",
    "member:save-pco-keychain": "bash functions/scripts/save-pco-credentials-keychain.sh",
    "updateSnapshots": "jest -u --coverage=false",
    "postinstall": "patch-package",
    "buildProduction:android": "EAS_BUILD_PROFILE=production npx eas-cli build --platform android --profile production",
    "buildProduction:ios": "EAS_BUILD_PROFILE=production npx eas-cli build --platform ios --profile production",
    "buildProduction:all": "EAS_BUILD_PROFILE=production npx eas-cli build --platform all --profile production",
    "buildDevelopment:ios": "EAS_BUILD_PROFILE=development npx eas-cli build --platform ios --profile development",
    "buildDevelopment:android": "EAS_BUILD_PROFILE=development npx eas-cli build --platform android --profile development",
    "buildDevelopment:all": "EAS_BUILD_PROFILE=development npx eas-cli build --platform all --profile development",
    "buildDevelopment:simulator": "npx eas-cli build --platform ios --profile development:simulator --local",
    "buildDevelopment:ios:local": "npx eas-cli build --platform ios --profile development --local",
    "buildDevelopment:android:local": "npx eas-cli build --platform android --profile development --local",
    "submitProduction": "EAS_BUILD_PROFILE=production npx eas submit --profile production",
    "admin:dev": "cd admin && npm run dev",
    "admin:build": "cd admin && npm run build",
    "admin:deploy": "cd admin && npm run build && firebase deploy --only hosting",
    "admin:set-admin": "node functions/scripts/set-admin-claim.cjs",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:all": "cd admin && npm run build && firebase deploy"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
