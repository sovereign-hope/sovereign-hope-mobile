  "private": true,
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-screens"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-track-player"
        ]
      }
    }
  },
  "name": "sovereign-hope-mobile",
  "version": "9.0.1"
}
