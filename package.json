    "@types/react-native-rss-parser": "^1.4.0",
    "axios": "^1.13.6",
    "cheerio": "npm:react-native-cheerio",
    "expo": "^54",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
