{
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "prepare": "husky install",
    "testChanged": "jest --watch --coverage=false --changedSince=origin/main",
    "testDebugCurrent": "jest -o --watch --coverage=false",
    "test": "jest",
    "updateSnapshots": "jest -u --coverage=false",
    "postinstall": "patch-package",
    "buildProduction:android": "EAS_BUILD_PROFILE=production npx eas-cli build --platform android --profile production",
    "buildProduction:ios": "EAS_BUILD_PROFILE=production npx eas-cli build --platform ios --profile production",
    "buildProduction:all": "EAS_BUILD_PROFILE=production npx eas-cli build --platform all --profile production",
    "buildDevelopment:ios": "EAS_BUILD_PROFILE=development npx eas-cli build --platform ios --profile development",
    "buildDevelopment:android": "EAS_BUILD_PROFILE=development npx eas-cli build --platform android --profile development",
    "buildDevelopment:all": "EAS_BUILD_PROFILE=development npx eas-cli build --platform all --profile development",
    "submitProduction": "EAS_BUILD_PROFILE=production npx eas submit --profile production"
  },
  "dependencies": {
    "@expo/config-plugins": "~10.1.1",
    "@expo/metro-config": "~0.20.0",
    "@expo/metro-runtime": "~5.0.4",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-firebase/analytics": "^18.3.0",
    "@react-native-firebase/app": "^18.3.0",
    "@react-native-menu/menu": "^1.1.2",
    "@react-navigation/bottom-tabs": "^6.0.9",
    "@react-navigation/native": "^6.0.2",
    "@react-navigation/native-stack": "^6.1.0",
    "@reduxjs/toolkit": "^2.4.0",
    "@sentry/react-native": "~6.14.0",
    "@types/cheerio": "^0.22.35",
    "@types/react-native-rss-parser": "^1.4.0",
    "axios": "^1.7.7",
    "cheerio": "npm:react-native-cheerio",
    "expo": "53.0.22",
    "expo-apple-authentication": "~7.2.4",
    "expo-application": "~6.1.5",
    "expo-auth-session": "~6.2.1",
    "expo-constants": "~17.1.7",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-haptics": "~14.1.4",
    "expo-notifications": "~0.31.4",
    "expo-secure-store": "~14.2.4",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-updates": "~0.28.17",
    "firebase": "^12.1.0",
    "node-html-parser": "^6.1.12",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-cheerio": "^1.0.0-rc.4",
    "react-native-collapsible": "^1.6.1",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-modal-datetime-picker": "^14.0.0",
    "react-native-progress": "^5.0.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-render-html": "^6.3.0",
    "react-native-rss-parser": "^1.5.1",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-track-player": "^5.0.0-alpha0",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5",
    "react-redux": "^9.2.0",
    "reselect": "^5.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-typescript": "7.14.5",
    "@eslint/compat": "^1.1.1",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.10.0",
    "@expo/config": "^11.0.0",
    "@testing-library/jest-native": "^4.0.1",
    "@testing-library/react-native": "^7.2.0",
    "@types/jest": "26.0.24",
    "@types/react": "~19.0.0",
    "@types/react-redux": "^7.1.34",
    "@types/react-test-renderer": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-typescript": "18.0.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-import": "2.30.0",
    "eslint-plugin-jest": "28.8.3",
    "eslint-plugin-jsx-a11y": "6.10.0",
    "eslint-plugin-promise": "7.1.0",
    "eslint-plugin-react": "7.35.2",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-react-native-a11y": "3.4.1",
    "eslint-plugin-unicorn": "55.0.0",
    "expo-build-properties": "~0.14.8",
    "globals": "^15.9.0",
    "husky": "6.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~53.0.10",
    "lint-staged": "11.0.0",
    "patch-package": "^6.5.0",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "2.3.1",
    "react-native-accessibility-engine": "^0.3.3",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3"
  },
  "private": true,
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect",
      "<rootDir>/jest/setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|react-clone-referenced-element|@react-native-community|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|native-base|@sentry/.*)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "json"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.{js,jsx,ts,tsx}",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/babel.config.js",
      "!**/.eslintrc.js"
    ]
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "name": "sovereign-hope-mobile",
  "version": "1.0.0"
}
